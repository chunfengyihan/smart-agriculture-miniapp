.feature-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.feature-header,
.picker-card,
.question-card,
.result-card,
.state {
  padding: 26rpx;
}

.feature-title {
  color: #16231c;
  font-size: 38rpx;
  font-weight: 800;
}

.feature-desc,
.summary,
.disclaimer {
  margin-top: 10rpx;
  color: #6b7d70;
  line-height: 1.55;
}

.picker-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.picker-card text:first-child {
  color: #6b7d70;
}

.picker-card text:last-child {
  color: #16231c;
  font-weight: 800;
  text-align: right;
}

.question-input {
  width: 100%;
  height: 220rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #f3f7f2;
  color: #16231c;
  line-height: 1.5;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.quick-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 22rpx;
  font-weight: 700;
}

.ask-button {
  margin-top: 22rpx;
}

.state {
  color: #6b7d70;
  text-align: center;
}

.result-title {
  color: #16231c;
  font-size: 34rpx;
  font-weight: 800;
}

.section-label {
  margin-top: 24rpx;
  color: #16231c;
  font-weight: 800;
}

.list-line {
  margin-top: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f3f7f2;
  color: #486154;
  line-height: 1.45;
}
