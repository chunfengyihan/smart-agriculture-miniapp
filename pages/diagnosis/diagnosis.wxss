.feature-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.feature-header,
.picker-card,
.upload-card,
.result-card,
.state {
  padding: 26rpx;
}

.feature-title {
  color: #16231c;
  font-size: 38rpx;
  font-weight: 800;
}

.feature-desc,
.paragraph,
.disclaimer {
  margin-top: 10rpx;
  color: #6b7d70;
  line-height: 1.55;
}

.picker-card,
.switch-row,
.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.picker-card text:first-child,
.switch-row text {
  color: #6b7d70;
}

.picker-card text:last-child {
  color: #16231c;
  font-weight: 800;
  text-align: right;
}

.image-picker {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  border: 2rpx dashed #bed4c2;
  border-radius: 14rpx;
  background: #f3f7f2;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #6b7d70;
  font-weight: 800;
}

.switch-row {
  margin-top: 22rpx;
}

.diagnose-button {
  margin-top: 24rpx;
}

.state {
  color: #6b7d70;
  text-align: center;
}

.result-title {
  color: #16231c;
  font-size: 34rpx;
  font-weight: 800;
}

.result-risk {
  margin-top: 8rpx;
  color: #6b7d70;
}

.result-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 22rpx;
  font-weight: 800;
}

.section-label {
  margin-top: 24rpx;
  color: #16231c;
  font-weight: 800;
}

.list-line {
  margin-top: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f3f7f2;
  color: #486154;
  line-height: 1.45;
}
