.detail-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.state {
  padding: 36rpx 28rpx;
  color: #6b7d70;
  text-align: center;
}

.state-title {
  margin-bottom: 12rpx;
  color: #16231c;
  font-size: 32rpx;
  font-weight: 800;
}

.state-message {
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.retry-button {
  width: 240rpx;
  margin: 0 auto;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  border-left: 8rpx solid #0f7a4c;
}

.detail-header.warning {
  border-left-color: #c98700;
}

.detail-header.offline {
  border-left-color: #7c8790;
}

.crop-label,
.detail-meta {
  color: #6b7d70;
  font-size: 24rpx;
}

.detail-title {
  margin: 10rpx 0;
  font-size: 40rpx;
  font-weight: 800;
}

.status-pill {
  min-width: 84rpx;
  height: 48rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  flex: 0 0 auto;
}

.status-pill.warning {
  background: #fff3d7;
  color: #9a6500;
}

.status-pill.offline {
  background: #edf0f2;
  color: #66737c;
}

.section-title {
  color: #16231c;
  font-size: 32rpx;
  font-weight: 800;
}

.tool-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tool-button {
  display: flex;
  min-height: 112rpx;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  width: 100%;
  padding: 22rpx 24rpx;
  text-align: left;
}

.tool-button text:first-child {
  color: #0f7a4c;
  font-size: 30rpx;
  font-weight: 800;
}

.tool-button text:last-child {
  color: #6b7d70;
  font-size: 23rpx;
  text-align: right;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.metric-card {
  min-height: 196rpx;
  padding: 22rpx;
  border-left: 6rpx solid #0f7a4c;
}

.metric-card.warning {
  border-left-color: #c98700;
}

.metric-card.critical {
  border-left-color: #bc3f3f;
}

.metric-label,
.metric-target,
.metric-status {
  color: #6b7d70;
  font-size: 23rpx;
}

.metric-value {
  margin: 14rpx 0 10rpx;
  color: #16231c;
  font-size: 38rpx;
  font-weight: 800;
}

.trend-card {
  padding: 8rpx 20rpx;
}

.chart-legend {
  display: flex;
  gap: 22rpx;
  padding: 18rpx 0 4rpx;
  color: #6b7d70;
  font-size: 22rpx;
}

.chart-legend view {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  flex: 0 0 auto;
}

.dot.temp {
  background: #0f7a4c;
}

.dot.humidity {
  background: #2864a8;
}

.dot.soil {
  background: #c98700;
}

.trend-canvas {
  width: 100%;
  height: 300rpx;
  margin-bottom: 8rpx;
}

.trend-row {
  display: grid;
  grid-template-columns: 1.25fr 1fr 1fr 1fr;
  gap: 12rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2ee;
  color: #486154;
  font-size: 22rpx;
}

.trend-row:last-child {
  border-bottom: 0;
}

.empty-line {
  padding: 28rpx 0;
  color: #6b7d70;
  text-align: center;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.alert-card {
  padding: 22rpx;
  border-left: 6rpx solid #7aa782;
}

.alert-card.warning {
  border-left-color: #c98700;
}

.alert-card.critical {
  border-left-color: #bc3f3f;
}

.alert-head {
  display: flex;
  justify-content: space-between;
  color: #6b7d70;
  font-size: 23rpx;
}

.alert-message {
  margin-top: 12rpx;
  color: #16231c;
  line-height: 1.6;
}
