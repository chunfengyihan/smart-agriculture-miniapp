.alerts-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.summary-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
}

.summary-title {
  color: #16231c;
  font-size: 38rpx;
  font-weight: 800;
}

.summary-desc {
  margin-top: 8rpx;
  color: #6b7d70;
  line-height: 1.5;
}

.summary-count {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 42rpx;
  font-weight: 800;
  flex: 0 0 auto;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-item {
  padding: 22rpx;
}

.summary-item text {
  display: block;
}

.summary-item text:first-child {
  color: #16231c;
  font-size: 38rpx;
  font-weight: 800;
}

.summary-item text:last-child {
  margin-top: 6rpx;
  color: #6b7d70;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border: 1rpx solid #cfded1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #486154;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.filter-chip.active {
  border-color: #0f7a4c;
  background: #e6f3eb;
  color: #0f7a4c;
}

.state {
  padding: 36rpx 28rpx;
  color: #6b7d70;
  text-align: center;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.alert-card {
  padding: 24rpx;
  border-left: 8rpx solid #7aa782;
}

.alert-card.warning {
  border-left-color: #c98700;
}

.alert-card.critical {
  border-left-color: #bc3f3f;
}

.alert-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.alert-title {
  color: #16231c;
  font-size: 31rpx;
  font-weight: 800;
}

.alert-meta,
.alert-time {
  margin-top: 8rpx;
  color: #6b7d70;
  font-size: 23rpx;
}

.level-pill {
  height: 46rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 21rpx;
  font-weight: 800;
  flex: 0 0 auto;
}

.level-pill.warning {
  background: #fff3d7;
  color: #9a6500;
}

.level-pill.critical {
  background: #fde8e8;
  color: #bc3f3f;
}

.alert-message {
  margin-top: 16rpx;
  color: #486154;
  line-height: 1.55;
}
