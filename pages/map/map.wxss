.map-page {
  position: relative;
  min-height: 100vh;
  background: #f5f7f4;
  overflow: hidden;
}

.greenhouse-map {
  width: 100%;
  height: 100vh;
}

.state {
  padding: 36rpx 28rpx;
  color: #6b7d70;
  text-align: center;
}

.map-list {
  position: absolute;
  z-index: 2;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  margin: 0;
  padding: 0 22rpx 22rpx;
  max-height: 680rpx;
  overflow: hidden;
  transition: max-height 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.28s ease;
}

.map-list.collapsed {
  max-height: 270rpx;
  padding-bottom: 18rpx;
  box-shadow: 0 10rpx 26rpx rgba(25, 63, 42, 0.1);
}

.map-list.dragging {
  transition: max-height 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.28s ease;
}

.sheet-handle-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  margin-bottom: 4rpx;
}

.sheet-handle {
  width: 82rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #cbd8cf;
  transition: width 0.22s ease, background 0.22s ease;
}

.map-list.expanded .sheet-handle {
  width: 104rpx;
  background: #aebfb4;
}

.map-list-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.map-list-title {
  color: #16231c;
  font-size: 32rpx;
  font-weight: 800;
}

.map-scroll {
  max-height: 34vh;
  animation: sheetContentIn 0.22s ease both;
}

.map-item {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 14rpx;
  border-bottom: 1rpx solid #edf2ee;
  border-radius: 12rpx;
}

.map-item:last-child {
  border-bottom: 0;
}

.map-item.active {
  background: #e6f3eb;
}

.map-item.compact {
  border-bottom: 0;
  animation: sheetContentIn 0.22s ease both;
  margin-top: 2rpx;
}

@keyframes sheetContentIn {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.item-name {
  color: #16231c;
  font-size: 30rpx;
  font-weight: 800;
}

.item-meta,
.item-address {
  margin-top: 6rpx;
  color: #6b7d70;
  font-size: 23rpx;
  line-height: 1.4;
}

.status-pill {
  min-width: 72rpx;
  height: 44rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #e6f3eb;
  color: #0f7a4c;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
  flex: 0 0 auto;
}

.status-pill.warning {
  background: #fff3d7;
  color: #9a6500;
}

.status-pill.offline {
  background: #edf0f2;
  color: #66737c;
}
