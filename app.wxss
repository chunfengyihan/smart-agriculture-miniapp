page {
  min-height: 100%;
  background: #f5f7f4;
  color: #16231c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
image,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.card {
  border: 1rpx solid #dce8dc;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(25, 63, 42, 0.08);
}

.muted {
  color: #6b7d70;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 12rpx;
  background: #0f7a4c;
  color: #ffffff;
  font-weight: 700;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  border: 1rpx solid #bed4c2;
  border-radius: 12rpx;
  color: #0f7a4c;
  font-weight: 700;
}
